#!/bin/sh
# 适应度桥 — 从**被驱动的项目**里拉不可伪造的 ground truth。
#
# 这是自举的核心:
#   founder-os 是**车**。被驱动的项目是**赛道**。**圈速骗不了人。**
#
# 为什么不能测"努力" (proactive / motivation / 卖力):
#   那些全是**可伪造的输入指标** —— agent 能刷想法数、刷 commit、写漂亮 journal。
#   (亲证的病例: 建了 11 个数据采集器、跑了 3 轮研究、日报天天好看、**真产出 = 0**。)
#   **别测卖力, 测结果。** 卖力只在能变成结果时才有价值。
#
# 输出两个不可伪造的数 (一快一慢):
#   SHIPPED  — 过了前向验证门的真产出 (需要真实市场数据 + 事前写死的门, 伪造不了)。**快**
#   MONEY    — 真钱净值 (交易所 API 拉的)。**慢** —— 短期被市场 beta 污染, canary 窗口须 ≥30 天
#
# 主适应度 = MONEY (最终的、无可辩驳的检验: 钱有没有赚到)
# 领先信号 = SHIPPED (结构性产出, beta 污染不了)
#
# --- 归因门的进化史 (每一版都是上一版的验尸报告) ---
# v1: grep "founder-os" — 安慰剂。赛道里恰好有 docs/founder-os.md → 恒真。
#     **测的是"字符串出现过", 不是"真的有归因"。**
# v2: 只认严格 trailer "Founder-OS-Shift: <班次名>"。但它是**电平计 + 一次性保险丝**:
#     一个 trailer (哪怕那份代码从没跑过) → 永久点亮 ATTRIBUTABLE → 把赛道的
#     **全部继承净值**一次性发给 founder-os ($8312.22, 已被巡检班验尸判假)。
#     **可归因 ≠ 有效。它把接触当成了贡献。**
# v3: 两刀 (详见 src/fitness_bridge.py 的 docstring):
#     1. 归因窗 30 天 (idea #6) — 曾经归因 ≠ 现在归因。窗决定「发不发」分。
#     2. 基线差分 — FITNESS = MONEY(now) − MONEY(epoch), epoch = 最早的 trailer commit。
#        接触发 0 分, 只有接触**之后**的变化计入。差分决定「发多少」分。
#        基线每次从不可伪造来源**现场重算** (无 seal 文件 = 无篡改面)。
#
# 逻辑全部住在 src/fitness_bridge.py —— 纯函数, 牙齿测试 (tests/) 咬得到。
# 这个壳只负责: 找到赛道、找到解释器、把控制权交出去。

set -u
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# 赛道路径的信任根 = 宪法 (GOAL.local.md > GOAL.md), 环境变量只作后备。
# 为什么: 本班实测环境变量被污染成了模板占位符 /absolute/path/to/your/project ——
# 「占位符 ≠ 配置」(fitness.py 同款伤疤), 且 agent 改不了 constitution/, 改得了 env。
GOALF="$ROOT/constitution/GOAL.local.md"
[ -f "$GOALF" ] || GOALF="$ROOT/constitution/GOAL.md"
TARGET="$(sed -n 's/^FOUNDER_TARGET=//p' "$GOALF" | head -1)"
[ -n "$TARGET" ] || TARGET="${FOUNDER_TARGET:-}"
case "$TARGET" in
  ""|*/absolute/path/*)
    # 失败要吵: 别 echo "0" —— 那会被 fitness.py 的 _num 当成一个合法读数。
    echo "🛑 赛道路径未配置 (拿到的是空值或模板占位符: '$TARGET')。去填 constitution/GOAL.local.md 的 FOUNDER_TARGET。" >&2
    exit 1;;
esac
[ -d "$TARGET" ] || { echo "🛑 赛道目录不存在: $TARGET (FOUNDER_TARGET 配错了?)" >&2; exit 1; }

PY="$TARGET/.venv/bin/python"
[ -x "$PY" ] || PY=python3

exec "$PY" "$ROOT/src/fitness_bridge.py" "$TARGET"
