#!/bin/sh
# 适应度桥 — 从**被驱动的项目**里拉不可伪造的 ground truth。
#
# 这是自举的核心:
#   founder-os 是**车**。被驱动的项目是**赛道**。**圈速骗不了人。**
#
# 为什么不能测"努力" (proactive / motivation / 卖力):
#   那些全是**可伪造的输入指标** —— agent 能刷想法数、刷 commit、写漂亮 journal。
#   (亲证的病例: 建了 11 个数据采集器、跑了 3 轮研究、日报天天好看、**真产出 = 0**。)
#   **别测卖力, 测结果。** 卖力只在能变成结果时才有价值。
#
# 输出两个不可伪造的数 (一快一慢):
#   SHIPPED  — 过了前向验证门的真产出 (需要真实市场数据 + 事前写死的门, 伪造不了)。**快**
#   MONEY    — 真钱净值 (交易所 API 拉的)。**慢** —— 短期被市场 beta 污染, canary 窗口须 ≥30 天
#
# 主适应度 = MONEY (最终的、无可辩驳的检验: 钱有没有赚到)
# 领先信号 = SHIPPED (结构性产出, beta 污染不了)
#
# --- 归因门 (idea #3, 由系统自己的思考班挖出) ---
# **不可伪造 ≠ 可归因。**
# founder-os 一行代码都没写进赛道时, SHIPPED/MONEY 测的是**赛道自己过去的活 + BTC 价格**,
# 不是 founder-os。那个 fitness 是一个**奉承我们的谎言**。
# 所以: 未写入赛道的样本 → ATTRIBUTABLE=0, 进化班**不许**用它判断变异去留。
#
# 它的不对称论证 (为什么别人不装这个传感器):
#   "一个用 fitness 判断自己变异去留的 agent, 绝不会主动装一个只能把自己分数打到零的传感器。
#    只有宪法把'诚实高于业绩'排在业绩之上的系统, 才付得起这个代价。"
# 我们装了。因为不装 = 亲手证明它是对的。

set -u
TARGET="${FOUNDER_TARGET:-/Users/luomazhang/ClaudWorkspace/trading}"
[ -d "$TARGET" ] || { echo "0"; exit 1; }

PY="$TARGET/.venv/bin/python"
[ -x "$PY" ] || PY=python3

"$PY" - "$TARGET" <<'PYEOF'
import json, sqlite3, sys
from pathlib import Path

T = Path(sys.argv[1])

# --- MONEY: 真钱净值 (交易所 API 记录, agent 伪造不了) ---
money = 0.0
try:
    c = sqlite3.connect(T / "data" / "oil_indicators.db")
    r = c.execute("SELECT value FROM indicators WHERE indicator='networth_usd' "
                  "ORDER BY period_date DESC LIMIT 1").fetchone()
    c.close()
    money = float(r[0]) if r else 0.0
except Exception:
    pass

# --- SHIPPED: 过了前向门的真产出 (28天真实数据 + 事前写死的门, 伪造不了) ---
shipped = 0
try:
    reg = json.loads((T / "data" / "strategy_registry.json").read_text())
    shipped = sum(1 for v in reg.values()
                  if isinstance(v, dict) and str(v.get("status", "")).startswith("live"))
except Exception:
    pass

# --- 归因: founder-os 的**班次**到底写过赛道吗? ---
# ⚠️ v1 是个安慰剂 (我在装它的几分钟内就踩了自己刚学到的教训):
#    它 grep commit message 里有没有 "founder-os" —— 而赛道仓库里恰好有个 docs/founder-os.md,
#    于是它返回 ATTRIBUTABLE=1。**它测的是"字符串出现过", 不是"真的有归因"。**
#    这是同一个抽象错误的**第四次**复发 (规矩写了≠被遵守 / 权限写了≠生效 / 声明≠有效能力)。
#
# v2: 只认**只有 founder-os 班次能产生**的严格 trailer。
#     班次写赛道时必须在 commit 里留: "Founder-OS-Shift: <班次名>"
#     没有这个 trailer = 我们对赛道的真实贡献 = **0**。不许自我安慰。
import subprocess
attributable = 0
try:
    r = subprocess.run(["git", "log", "--grep=^Founder-OS-Shift:", "--extended-regexp",
                        "--oneline", "-n", "1"],
                       cwd=T, capture_output=True, text=True, timeout=20)
    attributable = 1 if r.stdout.strip() else 0
except Exception:
    pass

print(f"SHIPPED={shipped}")
print(f"MONEY={money:.2f}")
print(f"ATTRIBUTABLE={attributable}")
if not attributable:
    print("# ⚠️ 归因门: founder-os 从未写入赛道 → 上面两个数**不可归因于我们**")
    print("#    它们测的是赛道自己过去的活 + BTC 价格。**进化班不许用它们判断变异去留。**")
    print("#    诚实的 founder-os 贡献 = 0")
print(f"FITNESS={money if attributable else 0:.2f}")
PYEOF
